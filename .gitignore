# ============================================================
# LunchMap .gitignore
# ============================================================
subscr-optimizer/


# ============================================================
# 【重要】実行時データ（個人情報・機密情報を含む）
# ============================================================
# ユーザーアカウント・セッション・リセットトークン・各ユーザーのサブスクデータ
# これらは絶対にリポジトリに含めてはいけません
backend/data/*.json

# ============================================================
# Node.js
# ============================================================
node_modules/

# ============================================================
# 生成ファイル（apidoc）
# ============================================================
# redoc-cli で openapi.yaml から生成される静的ドキュメント
# 生成物をコミットしたい場合はこの行を削除してください
# apidoc/

# ============================================================
# 環境変数・設定ファイル
# ============================================================
.env
.env.local
.env.*.local

# ============================================================
# PHP
# ============================================================
# エラーログ
*.log
php_errors.log

# Composer（将来 Composer を導入した場合）
/vendor/
composer.lock

# ============================================================
# macOS
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
._*

# ============================================================
# IDE / エディタ
# ============================================================
# VS Code（共有したい設定は .vscode/settings.json を別途管理）
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains（PhpStorm / WebStorm など）
.idea/
*.iml

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# ============================================================
# OS 共通
# ============================================================
Thumbs.db
Desktop.ini
